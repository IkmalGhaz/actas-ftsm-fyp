# ── Backend / MySQL ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=

DB_NAME=actas_db

# ── Express server ───────────────────────────────────────────────────────────
PORT=5000

# ── JWT (Auth token signing) ──────────────────────────────────────────────────
JWT_SECRET=

# ── Frontend URL (digunakan untuk bina link reset password) ──────────────────
FRONTEND_URL=http://localhost:5173

# ── Gmail / Nodemailer (Forgot Password feature) ─────────────────────────────
# Gunakan Gmail App Password (16 aksara), BUKAN kata laluan Gmail biasa.
# Panduan: https://myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_digit_app_password